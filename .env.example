# iConnect Environment Variables

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty to use SQLite)
DATABASE_URL=

# PostgreSQL (used if DATABASE_URL is set)
# DATABASE_URL=postgres://user:password@localhost:5432/pisowifi

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Cache (optional; defaults to REDIS_URL when set)
# CACHE_URL=redis://localhost:6379/1

# Timezone
TIMEZONE=Asia/Manila

# GPIO
GPIO_PIN=7
GPIO_SIMULATION=True
# Shared slot safety: keep fixed-device scoping disabled for multi-user queue attribution.
DEVICE_SCOPE_ENABLED=False
# DEVICE_MAC=AA:BB:CC:DD:EE:FF
DEVICE_API_KEY=replace-with-a-strong-device-api-key
ENFORCE_FIREWALL_BASELINE_ON_STARTUP=True
REQUIRE_FORWARD_DROP_BEFORE_SESSION=True
PORTAL_DEV_FLOW_ENABLED=False

# Security throttling
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
COIN_MAX_REQUESTS=120
COIN_WINDOW_SECONDS=60
COIN_REQUEST_WINDOW_SECONDS=45
COIN_REQUEST_MAX_QUEUE=20
VOUCHER_MAX_ATTEMPTS=8
VOUCHER_WINDOW_SECONDS=300
PUBLIC_MAX_REQUESTS=180
PUBLIC_WINDOW_SECONDS=60

# CORS (explicit allow-list; keep CORS_ALLOW_ALL_ORIGINS=False in production)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Electricity Rate (PHP per kWh)
ELECTRICITY_RATE=11.0

# Estimated utilization used for bandwidth approximation (0.0-1.0)
ESTIMATED_UTILIZATION_RATIO=0.35

# Production hardening (used when DEBUG=False)
# LAN captive-portal without TLS (HTTP)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# If you deploy valid HTTPS/TLS termination, switch to:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
